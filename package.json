{
  "name": "@chemistry/chemical-libraries",
  "version": "3.1.0",
  "description": "Open Cheminformatics Libraries",
  "type": "module",
  "author": {
    "name": "Volodymyr Vreshch",
    "url": "https://vreshch.com/"
  },
  "license": "MIT",
  "private": true,
  "keywords": [
    "cheminformatics",
    "chemistry",
    "javascript"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chemistry/chemical-libraries.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "npm run build -w @chemistry/common -w @chemistry/elements -w @chemistry/space-groups && npm run build -w @chemistry/math -w @chemistry/formula && npm run build -w @chemistry/molecule",
    "test": "vitest run",
    "lint": "eslint packages/*/src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "verify": "npm run type-check && npm run lint && npm run format:check && npm run test && npm run build",
    "clean": "rm -rf packages/*/dist coverage"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@eslint/js": "^10.0.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "prettier": "^3.4.0",
    "react": "^19.2.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.0"
  }
}
