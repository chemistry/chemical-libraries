{
  "name": "@chemistry/space-groups",
  "version": "3.1.3",
  "description": "List of space groups with symmetry codes",
  "type": "module",
  "author": {
    "name": "Volodymyr Vreshch",
    "url": "https://vreshch.com/"
  },
  "license": "MIT",
  "keywords": [
    "Crystallography",
